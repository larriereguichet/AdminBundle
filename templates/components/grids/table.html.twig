{% import '@LAGAdmin/grids/macro/attributes.html.twig' as lag_admin %}

<table {{ attributes.defaults({'class': 'admin-table table table-responsive align-middle'}) }}>
    {% block table_head %}
        {% if displayHeaders and headers|length > 0 %}
            <thead>
            <tr {{ headerRowAttributes }}>
                {%- for header in headers -%}
                    <th{{ headerAttributes.defaults({'class': 'text-dark'}) }}>
                        {{ component('lag_admin:grid:table_header', {
                            text: header.text,
                            translationDomain: header.translationDomain,
                            sortable: header.sortable,
                            ...header.attributes
                        }) }}
                    </th>
                {%- endfor -%}
            </tr>
            </thead>
        {% endif %}
    {% endblock %}

    {% block table_body %}
        {% if rows|length > 0 %}
            <tbody>
            {% for row in rows %}
                {% if row.form %}
                    {{ form_start(row.form) }}
                {% endif %}

                <tr{{ lag_admin.attributes(row.attributes) }}>
                    {% for cell in row.cells %}
                        <td{{ lag_admin.attributes(cell.attributes) }}>
                            {{ component('lag_admin:grid:cell', {cell: cell}) }}
                        </td>
                    {% endfor %}
                </tr>

                {% if row.form %}
                    {{ form_end(row.form) }}
                {% endif %}
            {% endfor %}
            </tbody>
        {% endif %}
    {% endblock %}

    {% block table_footer %}
        {% if this.rows|length == 0 %}
            <tfoot>
            <tr>
                <td colspan="{{ this.headers|length + 1 }}">
                    {{ 'lag_admin.ui.no_record'|trans({}, 'admin') }}
                </td>
            </tr>
            </tfoot>
        {% endif %}
    {% endblock %}
</table>
