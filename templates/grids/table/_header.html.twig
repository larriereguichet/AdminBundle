{% import '@LAGAdmin/grids/macro/attributes.html.twig' as lag_admin %}

{% if header.sortable %}
    <a{{ lag_admin.attributes(header.labelAttributes|merge({'class': 'text-dark'})) }}>
        {{ header.label|trans({}, header.translationDomain) }}

        {% if header.icon %}
            <i class="{{ header.icon }}"></i>
        {% end %}
    </a>
{% else %}
    <p{{ lag_admin.attributes(header.labelAttributes) }}>{{ header.label|trans({}, header.translationDomain) }}</p>
{% endif %}

